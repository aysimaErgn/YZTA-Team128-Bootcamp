# Yanımda Al — ortam değişkenleri şablonu (PR-3c)
# Kopyala: cp .env.example backend/.env   (veya proje köküne .env)

# --- Çalışma ortamı ---
PORT=8000
ENVIRONMENT=development
ORCHESTRATOR_ENABLED=true
# Virgülle ayrılmış origin listesi; * = tümü (MVP)
CORS_ORIGINS=*

# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key_here

# --- Supabase ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here
# SUPABASE_SERVICE_ROLE_KEY=  # alternatif anahtar adı (SUPABASE_KEY yoksa)

# --- Hafıza ---
MEMORY_USE_CHROMA=false

# --- Sağlık / eskalasyon eşikleri ---
HEALTH_PAIN_ESCALATION_THRESHOLD=7
SMS_PAIN_ESCALATION_THRESHOLD=9

# --- Twilio SMS (varsayılan stub) ---
FAMILY_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
FAMILY_SMS_OVERRIDE_PHONE=
